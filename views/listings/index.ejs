<% layout('/layouts/boilerplate') -%>
    <!-- <form action="/listings/new" method="get">
        <button>create New Listing</button>
    </form> -->
    <div class="filter-panel">
        <div id="filters">
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-city"></i></div>
                <p>Iconic Cities</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing Pools</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-tents"></i></div>
                <p>Camping</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-snowflake"></i></div>
                <p>Arctic</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-water"></i></div>
                <p>Resort</p>
            </div>
            <div class="filter">
                <div class="filter-icon"><i class="fa-solid fa-igloo"></i></div>
                <p>Igloo</p>
            </div>

            
        </div>
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch ">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <%for(listing of allListings){  %> 
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card" >
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing-image" style="height: 20rem;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%=listing.title %> <br></b>
                            &#8377;<%=listing.price.toLocaleString("en-IN") %>/night
                            &nbsp;<i class="tax-info">+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
        <% } %>
    </div>

    <script src="/js/index.js"></script>